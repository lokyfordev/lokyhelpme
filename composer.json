{
    "name": "lokyfordev/lokyhelpme",
    "description": "Interactive Laravel Artisan assistant for beginners",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "LokyHelpMe\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LokyHelpMe\\LokyHelpMeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
